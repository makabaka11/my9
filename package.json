{
  "name": "my9",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:test": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev -H 0.0.0.0",
    "share-count:snapshot": "node scripts/write-share-count-snapshot.mjs",
    "prebuild": "npm run share-count:snapshot",
    "build": "next build",
    "prebuild:cf": "npm run share-count:snapshot",
    "build:cf": "node scripts/build-next-cf.mjs",
    "start": "next start",
    "cf:verify-access": "node scripts/verify-cloudflare-access.mjs",
    "d1:migrate:local": "node scripts/run-wrangler-with-sql-token.mjs d1 migrations apply my9-prod --local",
    "d1:migrate:local:test": "node scripts/run-wrangler-with-sql-token.mjs d1 migrations apply my9-test --local --env=test",
    "d1:migrate:remote": "node scripts/run-wrangler-with-sql-token.mjs d1 migrations apply my9-prod --remote",
    "d1:migrate:remote:test": "node scripts/run-wrangler-with-sql-token.mjs d1 migrations apply my9-test --remote --env=test",
    "d1:rebuild-trends": "node scripts/rebuild-d1-trends-kind-v3.mjs",
    "d1:rebuild-trends:test": "node scripts/rebuild-d1-trends-kind-v3.mjs --env=test",
    "d1:cleanup-trends": "node scripts/cleanup-d1-trend-counts.mjs",
    "d1:cleanup-trends:test": "node scripts/cleanup-d1-trend-counts.mjs --env=test",
    "cf:build": "node scripts/run-opennext-cloudflare-build.mjs",
    "cf:build:test": "node scripts/run-opennext-cloudflare-build.mjs --env=test",
    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:deploy:test": "npm run cf:build:test && opennextjs-cloudflare deploy --env=test",
    "cf:sync-secrets": "node scripts/sync-cloudflare-secrets.mjs",
    "cf:sync-secrets:test": "node scripts/sync-cloudflare-secrets.mjs --env=test",
    "lint": "eslint .",
    "test:e2e": "node node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@opennextjs/cloudflare": "1.17.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-icons": "^5.6.0",
    "simple-icons": "^16.11.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "4.73.0"
  }
}
